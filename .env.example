# The Sentinel — environment configuration example.
# Copy to `.env` and fill in. All optional integrations are inert without their
# credentials even when the flag is on. Settings are read via get_settings().

# ── LLM enrichment ────────────────────────────────────────────────────────────
ENABLE_LLM=true
LLM_MAX_CALLS=1
LLM_TIMEOUT=10.0

# Provider is any OpenAI-compatible endpoint. Switch providers by editing the
# three vars below — no code change. LLM_API_KEY falls back to NVIDIA_API_KEY
# when unset (back-compat). Uncomment ONE preset.

# -- NVIDIA NIM (default; use a model that is actually served for your key) --
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-3.3-70b-instruct
LLM_API_KEY=
NVIDIA_API_KEY=your-nvidia-key-here

# -- Groq (free tier, fast; key from console.groq.com) --
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk_your_groq_key

# -- Google Gemini (free tier; key from aistudio.google.com) --
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-flash-latest
# LLM_API_KEY=your_gemini_key

# -- Ollama (local, free, offline; key is a dummy — Ollama ignores it) --
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5-coder:7b
# LLM_API_KEY=ollama

# ── Documentation review / translation ────────────────────────────────────────
ENABLE_DOC_REVIEW=true
ENABLE_TRANSLATION=false

# ── Durability (Redis) ─────────────────────────────────────────────────────────
# Set to make the job queue and webhook dedup survive restarts (and be shared
# across replicas). Unset = in-memory: single-process, lost on restart.
# Local Redis:      redis://localhost:6379/0
# docker compose sets redis://redis:6379/0 for you (see docker-compose.yml).
REDIS_URL=

# ── GitHub App (PR comment posting) ───────────────────────────────────────────
ENABLE_GITHUB=true
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
# Paste the PEM with literal \n between lines, or a real multi-line value.
GITHUB_PRIVATE_KEY=
GITHUB_API_BASE_URL=https://api.github.com
# Set in production to enforce X-Hub-Signature-256 webhook verification.
GITHUB_WEBHOOK_SECRET=
